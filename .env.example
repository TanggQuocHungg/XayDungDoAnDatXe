# Environment Configuration
# Sử dụng file này làm template để tạo file .env trong project

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/BEdatxe

# JWT Secret Key (thay đổi thành một chuỗi bí mật mạnh hơn cho production)
JWT_SECRET=your-secret-key-change-this-in-production

# Server Port
PORT=3000

# Node Environment
NODE_ENV=development
